{
  "include": ["src"],
  "compilerOptions": {
    "lib": ["ES2021.String"],
    "target": "ES2020",
    "module": "CommonJS",
    "esModuleInterop": true,
    "outDir": "dist",
    "emitDeclarationOnly": true,
    "declaration": true,
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "outFile": "dist/output.js"
  }
}
